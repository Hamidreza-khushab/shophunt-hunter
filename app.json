{
  "expo": {
    "name": "Shop Hunter",
    "slug": "shophunt-hunter",
    "scheme": [
      "shophunter",
      "com.olymaris.shophunter"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "backgroundColor": "#F8FBFF",
    "primaryColor": "#2563EB",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FBFF"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 192,
          "resizeMode": "contain",
          "backgroundColor": "#F8FBFF"
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Shop Hunter verwendet deinen Standort, um Spawns und Kampagnen in deiner Nähe auf der Karte anzuzeigen."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.olymaris.shophunter",
      "requireFullScreen": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.olymaris.shophunter",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "androidNavigationBar": {
      "visible": "immersive",
      "backgroundColor": "#0B1220",
      "barStyle": "light-content"
    },
    "extra": {
      "eas": {
        "projectId": "4dc74551-5e70-48dd-a8fd-ff5316e1eda6"
      }
    }
  }
}
